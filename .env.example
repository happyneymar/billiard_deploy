# Copy this file as .env locally if needed. Do not commit your real .env.
SECRET_KEY=replace-this-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com,.railway.app
CSRF_TRUSTED_ORIGINS=https://*.onrender.com,https://*.railway.app
DATABASE_URL=
TIME_ZONE=Asia/Shanghai
# Optional. Use this only if you mount a persistent disk/volume for uploads.
MEDIA_ROOT=/var/data/media
